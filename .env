# ── Base de datos MySQL ────────────────────────────────────────────────────────
# Credenciales del contenedor Docker (docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=disecan
DB_USER=disecan_user
DB_PASS=disecan_pass1234

# ── Ollama / LLM ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
